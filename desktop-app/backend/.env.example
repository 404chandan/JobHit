# JobHit Local Desktop App Environment Configuration
# Copy this file to a new file named '.env' and fill in your values.

# The port the local server will run on (accessible via http://localhost:5000/jobhit)
PORT=5000

# Environment mode (development / production)
NODE_ENV=development

# [MANDATORY] Your local or remote MongoDB Database connection URL.
# If running MongoDB locally, make sure MongoDB is started and use the local string.
DATABASE_URL=mongodb://127.0.0.1:27017/jobhit-local

# [MANDATORY] A 32-character hex encryption secret key used to secure credentials (like SMTP passwords and cookies) in your local database.
# Generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=your_32_character_hex_key_here

# [OPTIONAL] Gemini API Key for scoring jobs and generating cold email outreach drafts.
# You can also configure this API key directly in the settings panel within the application dashboard.
GEMINI_API_KEY=your_gemini_api_key_here
